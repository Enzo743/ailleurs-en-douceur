DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/ailleurs_en_douceur?schema=public"

# Mot de passe unique de l'administrateur
ADMIN_PASSWORD="change-me"

# Clé secrète JWT — générer avec : openssl rand -base64 32
JWT_SECRET="generate-with-openssl-rand-base64-32"

DOMAIN="test.com"

# Configuration Nodemailer pour l'envoi d'emails
# Exemple avec Gmail (nécessite un "App Password" si 2FA est activé)
EMAIL_USER="votre-email@gmail.com"
EMAIL_PASS="votre-mot-de-passe-ou-app-password"
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"
EMAIL_SECURE="false"
EMAIL_FROM="votre-email@gmail.com"  # Adresse email vérifiée de l'expéditeur

# Email du destinataire (optionnel - par défaut: EMAIL_USER)
CONTACT_RECIPIENT_EMAIL="email-de-votre-cliente@domaine.com"

# Base URL de l'application (pour générer les liens dans les emails)
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# ============================================
# Google OAuth2 pour Calendar API
# ============================================
# 1. Créer un projet sur https://console.cloud.google.com/
# 2. Activer l'API Google Calendar
# 3. Créer des identifiants OAuth2 (type "Application web")
# 4. Ajouter l'URI de redirection autorisée

GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:3000/api/google/callback"
GOOGLE_CALENDAR_ID="primary"  # ou l'ID spécifique de votre calendrier

# (Optionnel) Clé de service pour l'authentification server-to-server
# Alternative à OAuth2 pour les environnements de production
GOOGLE_SERVICE_ACCOUNT_EMAIL="your-service-account@project.iam.gserviceaccount.com"
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----"
GOOGLE_SERVICE_ACCOUNT_SUBJECT="adresse@mail.com"

# Cron secret clé
CRON_SECRET="generate-with-openssl-rand-base64-32"