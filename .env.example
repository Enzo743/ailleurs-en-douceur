DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/ailleurs_en_douceur?schema=public"

# Mot de passe unique de l'administrateur
ADMIN_PASSWORD="change-me"

# Clé secrète JWT — générer avec : openssl rand -base64 32
JWT_SECRET="generate-with-openssl-rand-base64-32"

# Configuration Nodemailer pour l'envoi d'emails
# Exemple avec Gmail (nécessite un "App Password" si 2FA est activé)
EMAIL_USER="votre-email@gmail.com"
EMAIL_PASS="votre-mot-de-passe-ou-app-password"
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"
EMAIL_SECURE="false"

# Email du destinataire (optionnel - par défaut: EMAIL_USER)
CONTACT_RECIPIENT_EMAIL="email-de-votre-cliente@domaine.com"
